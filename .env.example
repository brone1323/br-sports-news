# Secret used to authenticate Vercel cron job calls to /api/facebook/cron
# Set this in Vercel environment variables and in your Vercel cron config
FACEBOOK_CRON_SECRET=your-secret-here

# Gemini API key for rewriting articles before publishing
# Required — articles will NOT be published without a valid key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
